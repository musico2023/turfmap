# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real credentials.

# ─── Supabase ──────────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings → API → service_role (secret — never expose to client)
# Used by scripts/test-scan.ts to bypass RLS during seeding.
SUPABASE_SERVICE_ROLE_KEY=

# ─── DataForSEO ────────────────────────────────────────────────────────────
# https://app.dataforseo.com/api-access  (top right, "API Dashboard")
DFS_LOGIN=
DFS_PASSWORD=

# ─── Anthropic (Phase 3 AI Coach) ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Vercel Cron (Phase 3 weekly scheduled scans) ──────────────────────────
# Long random string. Vercel auto-injects when configured in project settings;
# set it here for local testing of /api/cron/weekly-scans.
# Generate with: openssl rand -hex 32
CRON_SECRET=
